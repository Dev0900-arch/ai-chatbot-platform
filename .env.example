# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Database (MySQL)
DATABASE_URL="mysql://user:password@localhost:3306/ai_chatbot_db"

# OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gmail SMTP (for lead notifications)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Paddle Billing
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your_paddle_client_side_token
NEXT_PUBLIC_PADDLE_ENV=sandbox
NEXT_PUBLIC_PADDLE_PRICE_MONTHLY=your_monthly_price_id
NEXT_PUBLIC_PADDLE_PRICE_YEARLY=your_yearly_price_id
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret
